            FRUIndex  INTEGER,
            deviceName DisplayString,
            ChassisPartNumber DisplayString,
            ChassisSerialNumber DisplayString,
            ChassisType DisplayString,
            ChassisOEM DisplayString,
            BoardManufacturer DisplayString,
            BoardProductName  DisplayString,
            BoardSerialNumber DisplayString,
            BoardPartNumber DisplayString,
            BoardOEM DisplayString,
            ManufacturerName DisplayString,
            ManufacturerDate DisplayString,
            ProductName DisplayString,
            ProductPartNumber DisplayString,
            ProductVersion DisplayString,
            ProductSerialNumber DisplayString,
            ProductOEM DisplayString,
            AssetTag DisplayString,
            FRUFileID DisplayString,
               }

    FRUIndex  OBJECT-TYPE
        SYNTAX  INTEGER
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " FRU ID "
        ::= { FRUEntry 1 }

    deviceName  OBJECT-TYPE
        SYNTAX  DisplayString (SIZE (0..128))
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " Chassis Type "
        ::= { FRUEntry 2 }

    ChassisPartNumber  OBJECT-TYPE
