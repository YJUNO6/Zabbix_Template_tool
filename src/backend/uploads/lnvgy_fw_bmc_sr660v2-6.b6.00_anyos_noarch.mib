    ChassisInfo OBJECT IDENTIFIER ::= { device 4 }

    ChassisTable OBJECT-TYPE
        SYNTAX SEQUENCE OF ChassisDetialData
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION " "
        ::= { ChassisInfo  2 }
 
    ChassisDetial OBJECT-TYPE
        SYNTAX ChassisDetialData
        MAX-ACCESS not-accessible
        STATUS current
        INDEX { ChassisIndex }
        --DESCRIPTION " "
        ::= { ChassisTable 1}

    ChassisDetialData::=
       SEQUENCE {
            ChassisIndex  INTEGER,
            PowerStatus INTEGER,
            PowerIdentify INTEGER,
            PowerPolicy INTEGER,
            RetartCause  INTEGER,
            Bootdev  INTEGER,
               }

    ChassisIndex  OBJECT-TYPE
        SYNTAX  INTEGER
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " "
        ::= { ChassisDetial 1 }

    PowerStatus  OBJECT-TYPE
        SYNTAX INTEGER {
            Off(0),
            On(1),
            Cycle(2),
            Reset(3),
            Diag(4),
            Soft(5)
        }
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION " "
        ::= { ChassisDetial 2 }

    PowerIdentify  OBJECT-TYPE
        SYNTAX INTEGER {
            Off(0),
            TimedOn(1),
            IndefiniteOn(2),
            Unknow(3)
        }
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION " "
        ::= { ChassisDetial 3 }

    PowerPolicy  OBJECT-TYPE
        SYNTAX INTEGER {
            Always-Off(0),
            Previous(1),
            Always-On(2),
            Unknow(3)
        }
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION " "
        ::= { ChassisDetial 4 }

    RetartCause  OBJECT-TYPE
        SYNTAX INTEGER {
            Unknow(0),
            PowerCtlCmd(1),
            ResetViaButton(2),
            PowerViaButton(3),
            Watchdog(4),
            OEM(5),
            PowerOnAC-policy-powerup(6),
            PowerOnAC-policy-always-on(7),
            PEF-Reset(8),
            PEF-Cycle(9),
            SoftReset(10),
            PowerUp-RTC(11)
        }
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " "
        ::= { ChassisDetial 5 }

    Bootdev  OBJECT-TYPE
        SYNTAX INTEGER {
            None(0),
            PXE(1),
            Disk(2),
            Safe(3),
            Diag(4),
            CDRom(5),
            BIOS(6),
            Floppy(7)
        }
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION " "
        ::= { ChassisDetial 6 }

