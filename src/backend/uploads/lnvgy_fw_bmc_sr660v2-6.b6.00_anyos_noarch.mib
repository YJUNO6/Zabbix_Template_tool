LENOVO-MIB DEFINITIONS ::= BEGIN

IMPORTS
    MODULE-IDENTITY, OBJECT-TYPE, TimeTicks FROM SNMPv2-SMI
       DisplayString, FROM SNMPv2-TC
    enterprises, IpAddress, Gauge, TimeTicks  ,NetworkAddress
        FROM RFC1155-SMI;
    device OBJECT IDENTIFIER ::= { enterprises 53184 }

    sensorInfo OBJECT IDENTIFIER ::= { device 1 }

    sensorTable OBJECT-TYPE
        SYNTAX SEQUENCE OF sensorEntryData
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION " "
        ::= { sensorInfo  2 }

    sensorEntry OBJECT-TYPE
        SYNTAX sensorEntryData
        MAX-ACCESS not-accessible
        STATUS current
        INDEX { SensorNum }
        --DESCRIPTION " "
        ::= { sensorTable 1 }

    sensorEntryData::=
        SEQUENCE {
            SensorNum  INTEGER,
            SensorType INTEGER,
            SensorName DisplayString,
            SensorReading DisplayString,
            SensorStatus  DisplayString,
                }

    SensorNum  OBJECT-TYPE
        SYNTAX  INTEGER
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " "
        ::= { sensorEntry 1 }

    --add enum value
    SensorType  OBJECT-TYPE
        SYNTAX INTEGER {
            Unknow(0),
            Temperature(1),
            Voltage(2),
            Current(3),
            Fan(4),
            ChassisIntrusion(5),
            ViolationAttempt(6),
            Processor(7),
            PowerSupply(8),
            PowerUnit(9),
            Coolingdevice(10),
            OtherUnit-based(11),
            Memory(12),
            DriveSlot(13),
            POSTmemoryResize(14),
            SystemFirmware(15),
            EventLoggingDisabled(16),
            Watchdog2(35),
            CriticalInterrupt(19),
            SystemEvent(18),
            PowerButton(20),
            BMCStart(22),
            RestartInit(29),
            ACPI(34),
            ManagementSubsystem(40)
        }
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " "
        ::= { sensorEntry 2 }

    SensorName  OBJECT-TYPE
        SYNTAX  DisplayString (SIZE (0..128))
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " "
        ::= { sensorEntry 3 }

    SensorReading  OBJECT-TYPE
        SYNTAX  DisplayString (SIZE (0..128))
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " "
        ::= { sensorEntry 4 }

    SensorStatus  OBJECT-TYPE
        SYNTAX  DisplayString (SIZE (0..128))
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION " "
        ::= { sensorEntry 5 }

    FRUInfo OBJECT IDENTIFIER ::= { device 2 }

    FRUTable OBJECT-TYPE
        SYNTAX SEQUENCE OF FRUEntryData
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION " "
        ::= { FRUInfo  2 }

    FRUEntry OBJECT-TYPE
        SYNTAX FRUEntryData
        MAX-ACCESS read-write
        STATUS current
        INDEX { FRUIndex }
